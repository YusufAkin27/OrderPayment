<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Modern ve Sade Tasarım</title>
    <link rel="stylesheet" href="~/css/UserHome.css" />
</head>
<body>
    <header>
        <div class="logo">LOGO</div>
        <div class="search-bar">
            <input type="text" placeholder="Ara..." />
        </div>
        <div class="icons">
            <span>🛒</span>
            <span>👤</span>
        </div>
    </header>

    <nav>
        <ul>
            <li><a href="#">Ana Sayfa</a></li>
            <li><a href="#">Ürünler</a></li>
            <li><a href="#">Kampanyalar</a></li>
            <li><a href="#">Hakkımızda</a></li>
        </ul>
    </nav>

    <main>
        <section class="hero">
            <h1>Hoş Geldiniz</h1>
            <p>En iyi ürünler burada!</p>
            <button>Keşfet</button>
        </section>

        <section class="product-list">
            <article class="product-card">
                <img src="product1.jpg" alt="Ürün 1" />
                <h3>Ürün Adı</h3>
                <p>₺100,00</p>
            </article>
            <article class="product-card">
                <img src="product2.jpg" alt="Ürün 2" />
                <h3>Ürün Adı</h3>
                <p>₺150,00</p>
            </article>
        </section>
    </main>

    <footer>
        <p>&copy; 2024 Modern Tasarım. Tüm hakları saklıdır.</p>
        <div class="social-media">
            <a href="#">Facebook</a>
            <a href="#">Twitter</a>
            <a href="#">Instagram</a>
        </div>
    </footer>
</body>
</html>


<!-- JavaScript Dosyası -->
<script src="~/js/UserHome.js"></script>
