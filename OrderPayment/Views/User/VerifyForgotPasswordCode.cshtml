<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SMS Doğrulama</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/VerifyLoginCode.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>
<body>

    <div class="container mt-5">
        <h1 class="text-center mb-4">SMS Doğrulama</h1>

        <!-- Kalan süre alanı -->
        <div id="remainingTimeMessage" class="alert alert-info text-center" role="alert">
            Kod süresi dolmadan doğrulama yapın. Kalan süre: <span id="remainingTime">02:00</span>
        </div>

        <!-- Doğrulama kodu alanı -->
        <div id="codeInputContainer" class="d-flex justify-content-center mb-3">
            <input type="text" maxlength="1" class="code-input form-control text-center me-1" id="code1" required>
            <input type="text" maxlength="1" class="code-input form-control text-center me-1" id="code2" required>
            <input type="text" maxlength="1" class="code-input form-control text-center me-1" id="code3" required>
            <input type="text" maxlength="1" class="code-input form-control text-center me-1" id="code4" required>
            <input type="text" maxlength="1" class="code-input form-control text-center me-1" id="code5" required>
            <input type="text" maxlength="1" class="code-input form-control text-center" id="code6" required>
        </div>

        <!-- Doğrulama butonu -->
        <button id="verifyButton" class="btn btn-primary w-100 mb-3">Doğrula</button>

        <!-- Sonuç mesajı -->
        <div id="resultMessage" class="mt-3 text-center"></div>

        <!-- Yeniden gönder butonu -->
        <button id="resendButton" class="btn btn-secondary w-100" disabled>Yeniden Kod Gönder</button>
    </div>

    <script src="~/js/VerifyForgotPassword.js"></script>
</body>
</html>
