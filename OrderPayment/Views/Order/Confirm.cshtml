<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Order</title>
    <link rel="stylesheet" href="~/css/Confirm.css">
</head>
<body>
    <!-- Main Checkout Container -->
    <div class="checkout-container">
        <!-- Checkout Header Section -->
        <div class="checkout-header">
            <h1>Checkout</h1>
            <p>Review your items and fill in your card details to complete the payment.</p>
        </div>

        <!-- Order Summary Section -->
        <div class="order-summary">
            <h2>Order Summary</h2>
            <div id="order-items">
                <!-- Sepetteki ürünler dinamik olarak buraya yüklenecek -->
                <p>Loading your cart...</p>
            </div>
            <div class="total-price">
                <strong>Total:</strong> <span id="total-price">$0.00</span>
            </div>
        </div>

        <!-- Card Details Section -->
        <div class="card-details">
            <div id="card" class="card">
                <!-- Card Front (Only One Side) -->
                <div class="card-front">
                    <!-- Card Number Input -->
                    <div class="card-number">
                        <input type="text" id="card-number" placeholder="Card Number" maxlength="19" oninput="formatCardNumber(this)" required>
                    </div>

                    <!-- Card Owner Input -->
                    <div class="card-owner">
                        <input type="text" id="card-owner" placeholder="Card Holder" oninput="checkPaymentButton()" required>
                    </div>

                    <!-- Expiry Date and CVV Input -->
                    <div class="card-expiry-cvv">
                        <input type="text" id="expiry-date" placeholder="MM/YY" maxlength="5" oninput="formatExpiryDate(this)" required>
                        <input type="text" id="cvv" placeholder="CVV" maxlength="3" oninput="checkPaymentButton()" required>
                    </div>
                </div>
            </div>
            <!-- Payment Button -->
            <button id="pay-button" class="btn" disabled>Pay Now</button>
        </div>
    </div>

    <!-- Link to JavaScript file (for card number formatting and validation) -->
    <script src="~/js/Confirm.js"></script>
</body>
</html> 