@model OrderPayment.Models.Request.UpdateUserRequest

@{
    ViewData["Title"] = "Kullanıcı Bilgilerini Düzenle";
}

<h2>@ViewData["Title"]</h2>

<form id="editUserForm" method="post">
    <input type="hidden" id="Id" name="Id" value="@Model.Id" /> <!-- ID'yi gizli alanda tutuyoruz -->

    <div class="form-group">
        <label for="FirstName">Ad</label>
        <input type="text" id="FirstName" name="FirstName" class="form-control" value="@Model.FirstName" />
        @if (!string.IsNullOrEmpty(Model.FirstName))
        {
            <small class="text-muted">Adınızı değiştirmek isterseniz burayı güncelleyebilirsiniz.</small>
        }
    </div>

    <div class="form-group">
        <label for="LastName">Soyad</label>
        <input type="text" id="LastName" name="LastName" class="form-control" value="@Model.LastName" />
        @if (!string.IsNullOrEmpty(Model.LastName))
        {
            <small class="text-muted">Soyadınızı değiştirmek isterseniz burayı güncelleyebilirsiniz.</small>
        }
    </div>

    <div class="form-group">
        <label for="PhoneNumber">Telefon Numarası</label>
        <input type="text" id="PhoneNumber" name="PhoneNumber" class="form-control" value="@Model.PhoneNumber" />
        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
        {
            <small class="text-muted">Telefon numaranızı değiştirmek isterseniz burayı güncelleyebilirsiniz.</small>
        }
    </div>

    <div class="form-group">
        <label for="IsActive">Aktif Mi?</label>
        <input type="checkbox" id="IsActive" name="IsActive" class="form-control" @(Model.IsActive ? "checked" : "") />
        @if (Model.IsActive)
        {
            <small class="text-muted">Kullanıcı aktif durumunda. Durumu değiştirmek isterseniz burayı güncelleyebilirsiniz.</small>
        }
    </div>

    <button type="submit" class="btn btn-primary">Güncelle</button>
    <a href="@Url.Action("Users", "Admin")" class="btn btn-secondary">İptal Et</a>
</form>

@section Scripts {
    <script>
        document.getElementById('editUserForm').addEventListener('submit', function (event) {
            // Form verilerini almak
            var firstName = document.getElementById('FirstName').value;
            var lastName = document.getElementById('LastName').value;
            var phoneNumber = document.getElementById('PhoneNumber').value;

            // Hata mesajlarını gösterecek bir kontrol
            var errorMessage = '';

            // Basit doğrulama - Boş alan kontrolü
            if (!firstName) {
                errorMessage += 'Ad alanı boş olamaz.\n';
            }
            if (!lastName) {
                errorMessage += 'Soyad alanı boş olamaz.\n';
            }
            if (!phoneNumber) {
                errorMessage += 'Telefon numarası boş olamaz.\n';
            }

            // Eğer hata varsa formu gönderme ve hata mesajını göster
            if (errorMessage) {
                event.preventDefault(); // Formu göndermemek için engelle
                alert(errorMessage); // Hata mesajını göster
            }
        });
    </script>
}
